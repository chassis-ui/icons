---
import IconsLayout from '@layouts/IconsLayout.astro'
import { getConfig } from '@libs/config'
import { iconsPages } from '@libs/content'
import List from '@components/icons/List.astro'

export async function getStaticPaths() {
  // Collect all tags from icon pages
  const tags = new Set()

  iconsPages.forEach(page => {
    if (page.data.tags) {
      const iconTags = Array.isArray(page.data.tags) ? page.data.tags : page.data.tags.split(',').map(tag => tag.trim())
      iconTags.forEach(tag => tags.add(tag))
    }
  })

  return Array.from(tags).map(tag => {
    const tagIcons = iconsPages.filter(page => {
      if (!page.data.tags) return false
      const iconTags = Array.isArray(page.data.tags) ? page.data.tags : page.data.tags.split(',').map(t => t.trim())
      return iconTags.includes(String(tag))
    })

    return {
      params: { tag },
      props: {
        tag,
        icons: tagIcons,
        count: tagIcons.length
      }
    }
  })
}

const { tag, icons, count } = Astro.props
const config = await getConfig()

const frontmatter = {
  title: `${String(tag).charAt(0).toUpperCase() + String(tag).slice(1)} icons`,
  description: `Browse ${count} icons tagged with "${tag}"`,
  tags: [tag]
}
---

<IconsLayout frontmatter={frontmatter}>
  <nav aria-label="breadcrumb">
    <div class="border-bottom border-subtle mb-medium">
      <ol class="breadcrumb">
        <li class="breadcrumb-page"><a href="/docs/icons">Icons</a></li>
        <li class="breadcrumb-page"><a href="/docs/icons/browse">Browse</a></li>
        <li class="breadcrumb-page active" aria-current="page">{tag}</li>
      </ol>
    </div>
  </nav>
  <div class="border-bottom border-subtle">
    <h1>{frontmatter.title}</h1>
    <p>{frontmatter.description}</p>
  </div>

  <List icons={icons} title={`Icons with ${String(tag).charAt(0).toUpperCase() + String(tag).slice(1)} tag`} />
</IconsLayout>
