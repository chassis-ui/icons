---
import IconsLayout from '@layouts/IconsLayout.astro'
import { iconsPages } from '@libs/content'
import Details from '@components/icons/Details.astro'

export async function getStaticPaths() {
  return iconsPages.map((iconsPage) => {
    // Use the title as the slug since title now contains the filename
    return {
      params: { slug: iconsPage.data.title },
      props: iconsPage
    }
  })
}

const { id, data, body } = Astro.props
const frontmatter = data
---

<IconsLayout frontmatter={frontmatter} id={id}>
  <Details icon={frontmatter} />
</IconsLayout>
