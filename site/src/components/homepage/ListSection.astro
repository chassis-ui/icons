---
import { iconsPages } from '@libs/content'

interface Props {
  icons?: typeof iconsPages
  showSearch?: boolean
  title?: string
}

const { icons = iconsPages, showSearch = true, title = 'Icons' } = Astro.props
---

<section id="icons-section" class="home-section py-3xlarge py-medium-6xlarge">
  <div class="container-2xlarge section-content">
    <header class="d-flex my-2xlarge">
      <h2 id="icons">{title}</h2>
      {
        showSearch && (
          <form class="flex-nowrap ms-auto" onsubmit="return false">
            <label for="search" class="visually-hidden">
              Search for icons
            </label>
            <input
              class="form-input search mb-0"
              id="search"
              type="search"
              placeholder="Start typing to filter..."
              autocomplete="off"
            />
          </form>
        )
      }
    </header>
    <ul
      id="icons-list"
      class="row row-cols-3 gy-medium row-cols-small-4 row-cols-large-6 row-cols-xlarge-8 bulletless icons-list icon-xlarge"
    >
      {
        icons.map((iconPage) => {
          const filename = iconPage.id.split('/').pop()?.replace('.mdx', '')
          if (!filename) return null
          return (
            <li
              class="col"
              data-name={filename}
              data-tags={iconPage.data.tags?.split(',')?.join(' ').toLowerCase()}
              data-categories={iconPage.data.categories?.split(',')?.join(' ').toLowerCase()}
            >
              <a class="d-block text-decoration-none" href={`/icons/${filename}`}>
                <div class="bg-even py-3xlarge text-center rounded">
                  <svg class="icon">
                    <use xlink:href={`#${filename}`} />
                  </svg>
                </div>
                <div class="name text-muted text-decoration-none text-center">{filename}</div>
              </a>
            </li>
          )
        })
      }
    </ul>
  </div>
</section>
<Fragment slot="scripts">
  <script src="../../assets/icon-search.js"></script>
</Fragment>
