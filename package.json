{
  "name": "@chassis-ui/icons",
  "version": "0.1.1",
  "type": "module",
  "description": "Comprehensive SVG icon library for Chassis Design System. Features optimized icons with automated font generation, sprite creation, and multi-format distribution for web and mobile applications.",
  "repository": {
    "type": "git",
    "url": "https://github.com/chassis-ui/icons.git"
  },
  "bugs": {
    "url": "https://github.com/chassis-ui/icons/issues"
  },
  "homepage": "https://chassis-ui.com",
  "author": "Ozgur Gunes <o.gunes@gmail.com>",
  "license": "MIT",
  "keywords": [
    "chassis",
    "design system",
    "icons",
    "icon font",
    "svg",
    "svg sprite",
    "fantasticon",
    "icon generator"
  ],
  "main": "icons/chassis-icons.css",
  "style": "icons/chassis-icons.css",
  "sass": "icons/chassis-icons.scss",
  "files": [
    "icons/*.{woff,woff2,css,scss,svg,json}",
    "svgs/*.svg",
    "!.DS_Store"
  ],
  "chassis": {
    "defaults": {
      "iconPrefix": "chassis-icon",
      "iconFormat": "woff2"
    },
    "icons": {
      "sprite": "chassis-icons.svg",
      "font": "chassis-icons",
      "preview": "preview.html"
    }
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "pnpm icons && pnpm site:pages && pnpm site:build",
    "dev": "pnpm astro:dev",
    "release": "pnpm build && pnpm icons:zip",
    "test": "pnpm site:build && pnpm icons:check",
    "icons": "rm -rf icons/*.{css,scss,woff,woff2,svg} && pnpm icons:svgs --aggregate-output --parallel && pnpm icons:sprite && pnpm icons:font",
    "icons:check": "node build/check-icons.js",
    "icons:font": "pnpm icons:font-main && pnpm icons:font-min",
    "icons:font-main": "node build/build-icons.js",
    "icons:font-min": "cleancss -O1 --format breakWith=lf --with-rebase --output icons/chassis-icons.min.css icons/chassis-icons.css",
    "icons:lint": "eslint --cache --cache-location .cache/.eslintcache build",
    "icons:sprite": "svg-sprite --config svg-sprite.json --log=info \"svgs/*.svg\"",
    "icons:svgs": "node build/build-svgs.js",
    "icons:zip": "node build/zip-icons.js",
    "site": "pnpm site:build && pnpm site:lint",
    "site:pages": "node build/build-pages.js",
    "site:build": "pnpm sync-submodules && pnpm astro:build",
    "site:format": "prettier --write --cache site",
    "site:lint": "pnpm site:lint:eslint && pnpm site:lint:stylelint && pnpm site:lint:prettier && pnpm site:lint:vnu",
    "site:lint:fusv": "find-unused-sass-variables site/src/scss/",
    "site:lint:eslint": "eslint site --cache --cache-location .cache/.eslintcache --report-unused-disable-directives",
    "site:lint:prettier": "prettier -c --cache site",
    "site:lint:stylelint": "stylelint site/src/scss/ --cache --cache-location .cache/.stylelintcache",
    "site:lint:vnu": "node build/vnu-jar.js",
    "astro:dev": "astro dev --root site --port 4324",
    "astro:build": "astro build --root site",
    "astro:preview": "astro preview --root site",
    "check": "pnpm check:lockfile & pnpm check:pnpm & wait",
    "check:lockfile": "lockfile-lint --allowed-hosts npm --allowed-schemes https: --empty-hostname false --type npm --path package-lock.json",
    "check:pnpm": "pnpm audit --audit-level moderate",
    "change-version": "node build/change-version.js",
    "sync-submodules": "node build/sync-submodules.js"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@astrojs/markdown-remark": "^6.3.11",
    "@astrojs/mdx": "^4.3.14",
    "@astrojs/prism": "^3.3.0",
    "@astrojs/sitemap": "^3.7.2",
    "@chassis-ui/css": "github:chassis-ui/css#app/docs",
    "@chassis-ui/docs": "^0.1.9",
    "@chassis-ui/tokens": "github:chassis-ui/tokens#app/docs",
    "@docsearch/css": "^3.9.0",
    "@docsearch/js": "^3.9.0",
    "@eslint/js": "^9.39.4",
    "@stackblitz/sdk": "^1.11.0",
    "@twbs/fantasticon": "^3.1.0",
    "@types/hast": "^3.0.4",
    "@types/js-yaml": "^4.0.9",
    "@types/mdast": "^4.0.4",
    "@types/node": "^22.19.17",
    "@types/prismjs": "^1.26.6",
    "@types/unist": "^3.0.3",
    "astro": "^5.18.1",
    "astro-auto-import": "^0.4.6",
    "autoprefixer": "^10.5.0",
    "clean-css-cli": "^5.6.3",
    "clipboard": "^2.0.11",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-astro": "^1.7.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-unicorn": "^61.0.2",
    "find-unused-sass-variables": "^6.1.1",
    "github-slugger": "^2.0.0",
    "globals": "^16.5.0",
    "hast": "^1.0.0",
    "htmlparser2": "^10.1.0",
    "image-size": "^2.0.2",
    "js-yaml": "^4.1.1",
    "lockfile-lint": "^4.14.1",
    "mdast-util-from-markdown": "^2.0.3",
    "mdast-util-mdx-jsx": "^3.2.0",
    "mdast-util-to-string": "^4.0.0",
    "mime": "^4.1.0",
    "npm-run-all": "^4.1.5",
    "picocolors": "^1.1.1",
    "postcss": "^8.5.11",
    "postcss-cli": "^11.0.1",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "prismjs": "^1.30.0",
    "rehype-autolink-headings": "^7.1.0",
    "remark": "^15.0.1",
    "remark-html": "^16.0.1",
    "sass": "1.78.0",
    "sharp": "^0.33.5",
    "standard": "^17.1.2",
    "stylelint": "^16.26.1",
    "stylelint-config-twbs-bootstrap": "^16.1.0",
    "svg-sprite": "3.0.0-rc3",
    "svgo": "^3.3.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.0",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0",
    "vnu-jar": "23.4.11",
    "zod": "^3.25.76"
  },
  "packageManager": "pnpm@10.33.2+sha512.a90faf6feeab71ad6c6e57f94e0fe1a12f5dcc22cd754db40ae9593eb6a3e0b6b12e3540218bb37ae083404b1f2ce6db2a4121e979829b4aff94b99f49da1cf8"
}
