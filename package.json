{
  "name": "@ozgurgunes/chassis-icons",
  "version": "0.1.0",
  "type": "module",
  "description": "Icon generator and font builder for Chassis Design System. Includes SVG optimization, sprite generation, and icon font creation.",
  "license": "MIT",
  "homepage": "https://github.com/ozgurgunes/chassis-icons",
  "repository": {
    "type": "git",
    "url": "https://github.com/ozgurgunes/chassis-icons.git"
  },
  "bugs": {
    "url": "https://github.com/ozgurgunes/chassis-icons/issues"
  },
  "keywords": [
    "chassis",
    "design system",
    "icons",
    "icon font",
    "svg",
    "svg sprite",
    "fantasticon",
    "icon generator"
  ],
  "main": "font/chassis-icons.css",
  "style": "font/chassis-icons.css",
  "sass": "font/chassis-icons.scss",
  "files": [
    "font/*.{woff,woff2,css,scss,svg,json}",
    "svgs/*.svg",
    "!.DS_Store"
  ],
  "chassis": {
    "defaults": {
      "iconPrefix": "chassis-icon",
      "iconFormat": "woff2"
    },
    "icons": {
      "sprite": "chassis-icons.svg",
      "font": "chassis-icons",
      "preview": "preview.html"
    }
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=9.0.0"
  },
  "pnpm": {
    "overrides": {
      "devalue": ">=5.3.2",
      "brace-expansion": ">=2.0.2"
    }
  },
  "scripts": {
    "build": "pnpm icons",
    "build:site": "node build/build-site.js",
    "build:astro": "astro build --root site",
    "build:pages": "node build/build-pages.js",
    "dev:site": "astro dev --root site --port 4323",
    "icons": "rm -rf font/*.{css,scss,woff,woff2,svg} && pnpm icons-main --aggregate-output --parallel && pnpm icons-sprite && pnpm icons-font",
    "icons-main": "node build/build-svgs.js",
    "icons-sprite": "svg-sprite --config svg-sprite.json --log=info \"svgs/*.svg\"",
    "icons-font": "pnpm icons-font-main && pnpm icons-font-min",
    "icons-font-main": "node build/build-icons.js",
    "icons-font-min": "cleancss -O1 --format breakWith=lf --with-rebase --output font/chassis-icons.min.css font/chassis-icons.css",
    "icons-zip": "node build/zip-icons.js",
    "check": "node build/check-icons.js",
    "sync:submodules": "node build/sync-submodules.js",
    "validate": "eslint . --fix && prettier --write .",
    "release-version": "node build/bump-version.js",
    "release": "pnpm build && pnpm icons-zip",
    "test:fusv": "find-unused-sass-variables site/src/scss/",
    "test:eslint": "eslint --cache --cache-location .cache/.eslintcache .",
    "test:stylelint": "stylelint site/src/scss/ --cache --cache-location .cache/.stylelintcache",
    "test:audit": "pnpm audit --audit-level moderate",
    "test:check-icons": "node build/check-icons.js",
    "test:vnu": "node build/vnu-jar.js",
    "test": "pnpm build:site && npm-run-all --parallel --aggregate-output --continue-on-error test:*"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.4",
    "@astrojs/markdown-remark": "^5.3.0",
    "@astrojs/mdx": "^4.3.4",
    "@astrojs/prism": "^3.3.0",
    "@astrojs/sitemap": "^3.5.1",
    "@docsearch/css": "^3.9.0",
    "@docsearch/js": "^3.9.0",
    "@ozgurgunes/chassis-css": "github:ozgurgunes/chassis-css#app/docs",
    "@ozgurgunes/chassis-tokens": "github:ozgurgunes/chassis-tokens#app/docs",
    "@stackblitz/sdk": "^1.11.0",
    "@twbs/fantasticon": "^3.1.0",
    "@types/hast": "^3.0.4",
    "@types/js-yaml": "^4.0.9",
    "@types/mdast": "^4.0.4",
    "@types/node": "^22.8.0",
    "@types/prismjs": "^1.26.5",
    "@types/unist": "^3.0.3",
    "astro": "^5.13.5",
    "astro-auto-import": "^0.4.4",
    "autoprefixer": "^10.4.21",
    "clean-css-cli": "^5.6.3",
    "clipboard": "^2.0.11",
    "eslint": "^9.34.0",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.4",
    "find-unused-sass-variables": "^6.1.0",
    "github-slugger": "^2.0.0",
    "hast": "^1.0.0",
    "htmlparser2": "^10.0.0",
    "image-size": "^2.0.2",
    "js-yaml": "^4.1.0",
    "lockfile-lint": "^4.14.1",
    "mdast-util-from-markdown": "^2.0.2",
    "mdast-util-mdx-jsx": "^3.2.0",
    "mdast-util-to-string": "^4.0.0",
    "mime": "^4.0.7",
    "npm-run-all": "^4.1.5",
    "picocolors": "^1.1.1",
    "postcss": "^8.5.6",
    "postcss-cli": "^11.0.1",
    "prettier": "^3.2.5",
    "prismjs": "^1.30.0",
    "rehype-autolink-headings": "^7.1.0",
    "remark": "^15.0.1",
    "remark-html": "^16.0.1",
    "sass": "^1.78.0",
    "sharp": "^0.33.0",
    "standard": "^17.1.0",
    "stylelint": "^16.23.1",
    "stylelint-config-twbs-bootstrap": "^16.1.0",
    "svg-sprite": "^3.0.0-rc2",
    "svgo": "^3.2.0",
    "typescript": "^5.6.0",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.0.0",
    "vnu-jar": "23.4.11",
    "zod": "^3.24.3"
  },
  "packageManager": "pnpm@9.15.5+sha512.845196026aab1cc3f098a0474b64dfbab2afe7a1b4e91dd86895d8e4aa32a7a6d03049e2d0ad770bbe4de023a7122fb68c1a1d6e0d033c7076085f9d5d4800d4"
}
